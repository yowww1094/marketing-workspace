# Supabase Configuration
# Retrieve these values by running `supabase status` when the local instance is running,
# or from your Supabase Dashboard for production.
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhb... (local anon key)"
SUPABASE_SERVICE_ROLE_KEY="eyJhb... (local service role key)"

# Nvidia Nim Api key
NVIDIA_API_KEY="your_nvidia_nim_key_here"

# App URLs
NEXT_PUBLIC_MARKETING_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3002"

# Stripe Configuration
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
